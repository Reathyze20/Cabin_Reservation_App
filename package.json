{
  "name": "cabin_reservation_app",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "tsx watch src/backend/server.new.ts",
    "dev:frontend": "cd frontend-v2 && npm run dev",
    "preflight:deploy": "npm run prisma:generate && npx tsc --noEmit && npm --prefix frontend-v2 run test:run && npm --prefix frontend-v2 run build",
    "build": "cd frontend-v2 && npm run build",
    "build:install": "cd frontend-v2 && npm ci && npm run build",
    "start": "NODE_ENV=production node --import tsx src/backend/server.new.ts",
    "preview": "npm run build && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "validate:ai": "tsx src/scripts/validateAiAssets.ts",
    "report:ai": "tsx src/scripts/reportAiGovernance.ts",
    "db:seed": "tsx src/scripts/migrateData.ts",
    "create-learning-admin": "tsx src/scripts/createLearningAdmin.ts",
    "backup:db": "tsx src/scripts/backupManager.ts backup db",
    "backup:uploads": "tsx src/scripts/backupManager.ts backup uploads",
    "backup:all": "tsx src/scripts/backupManager.ts backup all",
    "backup:smoke": "tsx src/scripts/backupRestoreSmoke.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:seed": "docker compose exec app npx tsx src/scripts/migrateData.ts"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "4.21.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^18.19.130",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  }
}
