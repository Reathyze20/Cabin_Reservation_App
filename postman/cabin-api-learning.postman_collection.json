{
  "info": {
    "name": "Cabin API Learning",
    "description": "Starter Postman collection for learning the CabinReservationProject backend. Mirrors the initial OpenAPI coverage and focuses on the most useful local learning flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/openapi.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "openapi.json"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.environment.set('authToken', data.token);",
                  "}",
                  "if (data.cabinId) {",
                  "  pm.environment.set('cabinId', data.cabinId);",
                  "}",
                  "if (data.userId) {",
                  "  pm.environment.set('userId', data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          }
        },
        {
          "name": "Get current cabin",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cabin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cabin"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "List reservations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reservations"
              ]
            }
          }
        },
        {
          "name": "Create reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.environment.set('reservationId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": \"2026-06-12\",\n  \"to\": \"2026-06-14\",\n  \"purpose\": \"Vikend na chate\",\n  \"notes\": \"Vezmeme deskovky\",\n  \"handoverNote\": \"Drevo je v kulne\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reservations"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Shopping and Inventory",
      "item": [
        {
          "name": "List shopping lists",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shopping-lists",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "shopping-lists"
              ]
            }
          }
        },
        {
          "name": "Create shopping list",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.environment.set('shoppingListId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vikendovy nakup\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shopping-lists",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "shopping-lists"
              ]
            }
          }
        },
        {
          "name": "List inventory",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            }
          }
        },
        {
          "name": "Create inventory item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kava\",\n  \"category\": \"TRVANLIVE\",\n  \"status\": \"OK\",\n  \"location\": \"Kredenc\",\n  \"isEssential\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "List channels",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/channels",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "channels"
              ]
            }
          }
        },
        {
          "name": "Create channel",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Organizace vikendu\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/channels",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "channels"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Gallery",
      "item": [
        {
          "name": "List gallery folders",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
                  "  pm.environment.set('folderId', data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/gallery/folders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "gallery",
                "folders"
              ]
            }
          }
        },
        {
          "name": "Create gallery folder",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.environment.set('folderId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Leto 2026\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/gallery/folders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "gallery",
                "folders"
              ]
            }
          }
        },
        {
          "name": "Upload photo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "folderId",
                  "value": "{{folderId}}",
                  "type": "text"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/gallery/photos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "gallery",
                "photos"
              ]
            },
            "description": "Vyberte skutecny lokalni soubor do pole photos a pouzijte folderId z predchoziho requestu."
          }
        }
      ]
    },
    {
      "name": "Admin and Logs",
      "item": [
        {
          "name": "Admin system stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/system",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "system"
              ]
            }
          }
        },
        {
          "name": "List log files",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/logs/files",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logs",
                "files"
              ]
            }
          }
        },
        {
          "name": "Read logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/logs?lines=50&source=backend",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logs"
              ],
              "query": [
                {
                  "key": "lines",
                  "value": "50"
                },
                {
                  "key": "source",
                  "value": "backend"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": []
}