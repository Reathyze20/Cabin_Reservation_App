# ==============================================================================
# Cabin Reservation App — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ==============================================================================

# ── Required ──────────────────────────────────────────────────────────

# JWT Secret Key — MUST change in production (min 32 chars recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=vas_super_tajny_klic_ktery_nikdo_neuhodne

# PostgreSQL Database Connection
# For local dev:
DATABASE_URL="postgresql://postgres:password@localhost:5432/cabin_reservation?schema=public"
# For Docker Compose (auto-configured, don't set manually):
# DATABASE_URL is built from POSTGRES_USER + POSTGRES_PASSWORD

# ── Docker Compose specific ───────────────────────────────────────────

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=cabin
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── Optional ──────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Uploads directory — override for custom mount points
# Default: ./data/uploads (relative to project root)
# Docker example: /data/uploads (mount a volume at /data)
# UPLOADS_PATH=/data/uploads

# Expose DB port to host (default: 5432) — for Prisma Studio / admin tools
DB_PORT=5432

# ── Amazon SES (SMTP) Email Configuration ────────────────────────────────
# Amazon SES credentials for sending verification emails
# Region: eu-central-1 (Frankfurt)
# Domain: chataceskestredohori.cz (ověřená v SES)
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=AKIAR************
SMTP_PASS=****************************
EMAIL_FROM="KdyNaChatu <noreply@chataceskestredohori.cz>"

# Frontend URL — used for verification links in emails
FRONTEND_URL=http://localhost:5173
