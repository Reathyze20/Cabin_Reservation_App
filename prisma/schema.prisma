// Prisma schema for Cabin Reservation App
// PostgreSQL database

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// APP SETTINGS (singleton — id = "singleton")
// ============================================================================
model AppSettings {
  id                 String  @id @default("singleton")
  pinnedHandoverNote String? @map("pinned_handover_note") @db.Text

  @@map("app_settings")
}

// ============================================================================
// USERS
// ============================================================================
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  color            String
  animalIcon       String?  @map("animal_icon")
  email            String?  @unique
  isEmailVerified  Boolean  @default(false) @map("is_email_verified")
  verificationCode String?  @map("verification_code")
  isVerified        Boolean  @default(false) @map("is_verified")
  verificationToken String?  @map("verification_token")
  role             String   @default("user") // "admin" | "user" | "guest"
  isSuperAdmin     Boolean  @default(false) @map("is_super_admin")
  isBanned         Boolean  @default(false) @map("is_banned")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  reservations              Reservation[]
  shoppingListItemsAdded    ShoppingListItem[]           @relation("AddedBy")
  shoppingListItemsPurchased ShoppingListItem[]          @relation("PurchasedBy")
  shoppingItemSplits        ShoppingItemSplit[]
  shoppingListsCreated      ShoppingList[]
  noteThreads               NoteThread[]
  notes                     Note[]
  galleryFolders            GalleryFolder[]
  galleryPhotos             GalleryPhoto[]
  diaryFolders              DiaryFolder[]
  diaryEntries              DiaryEntry[]
  reconstructionItems       ReconstructionItem[]
  reconstructionVotes       ReconstructionVote[]
  reservationWatches        ReservationWatcher[]
  inventoryUpdates          InventoryItem[]      @relation("UpdatedBy")
  availabilities            UserAvailability[]
  systemLogs                SystemLog[]

  @@map("users")
}

// ============================================================================
// RESERVATIONS
// ============================================================================
model Reservation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  dateFrom     DateTime @map("date_from") @db.Date
  dateTo       DateTime @map("date_to") @db.Date
  purpose      String
  notes        String?  @db.Text
  handoverNote String?  @map("handover_note") @db.Text
  status       String   @default("primary") // "primary" | "backup" | "soft"
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchers ReservationWatcher[]

  @@map("reservations")
}

// ============================================================================
// SHOPPING LIST
// ============================================================================

enum ItemStatus {
  pending
  bring_from_home
  purchased
}

model ShoppingList {
  id          String             @id @default(uuid())
  name        String
  createdById String             @map("created_by_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  isResolved  Boolean            @default(false) @map("is_resolved")
  isPantry    Boolean            @default(false) @map("is_pantry")

  // Relations
  createdBy   User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items       ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id            String     @id @default(uuid())
  listId        String?    @map("list_id") // Nullable initially for backward compatibility
  name          String
  addedById     String     @map("added_by_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  status        ItemStatus @default(pending)
  purchased     Boolean    @default(false) // kept for backward-compat; mirrors status === purchased
  purchasedById String?    @map("purchased_by_id")
  purchasedAt   DateTime?  @map("purchased_at")
  price               Decimal?   @db.Decimal(10, 2)
  linkedInventoryId   String?    @map("linked_inventory_id")
  isEssential         Boolean    @default(false) @map("is_essential")
  sourceMessageId     String?    @map("source_message_id")

  // Relations
  list        ShoppingList?       @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedBy     User                @relation("AddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  purchasedBy User?               @relation("PurchasedBy", fields: [purchasedById], references: [id], onDelete: SetNull)
  splits      ShoppingItemSplit[]

  @@map("shopping_list_items")
}

model ShoppingItemSplit {
  itemId String @map("item_id")
  userId String @map("user_id")

  // Relations
  item ShoppingListItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([itemId, userId])
  @@map("shopping_item_splits")
}

// ============================================================================
// NOTES & THREADS
// ============================================================================
model NoteThread {
  id          String   @id @default(uuid())
  name        String
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  createdBy User   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  notes     Note[]

  @@map("note_threads")
}

model Note {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  threadId         String?  @map("thread_id") // Null = General / Hlavní nástěnka
  message          String   @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  isResolvedAsTask Boolean  @default(false) @map("is_resolved_as_task")

  // Relations
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread NoteThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ============================================================================
// GALLERY
// ============================================================================
model GalleryFolder {
  id          String   @id @default(uuid())
  name        String   @unique
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  createdBy User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  photos    GalleryPhoto[]

  @@map("gallery_folders")
}

model GalleryPhoto {
  id            String   @id @default(uuid())
  folderId      String   @map("folder_id")
  src           String
  uploadedById  String?  @map("uploaded_by_id")
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  folder         GalleryFolder       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploadedBy     User?               @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  diaryEntries   DiaryEntryPhoto[]

  @@map("gallery_photos")
}

// ============================================================================
// DIARY
// ============================================================================
model DiaryFolder {
  id          String    @id @default(uuid())
  name        String
  createdById String    @map("created_by_id")
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  activityTag String?   @map("activity_tag")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  entries   DiaryEntry[]

  @@map("diary_folders")
}

model DiaryEntry {
  id        String   @id @default(uuid())
  folderId  String   @map("folder_id")
  authorId  String   @map("author_id")
  entryDate DateTime @map("entry_date") @db.Date
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  folder  DiaryFolder       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  photos  DiaryEntryPhoto[]

  @@map("diary_entries")
}

model DiaryEntryPhoto {
  entryId String @map("entry_id")
  photoId String @map("photo_id")

  // Relations
  entry DiaryEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  photo GalleryPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([entryId, photoId])
  @@map("diary_entry_photos")
}

// ============================================================================
// RECONSTRUCTION
// ============================================================================
model ReconstructionItem {
  id             String   @id @default(uuid())
  category       String   // "idea" | "company" | "task"
  title          String
  description    String   @db.Text
  link           String?
  cost           Decimal? @db.Decimal(10, 2)
  status         String   @default("pending") // "pending" | "approved" | "done"
  thumbnail      String?
  tag            String?
  specialization String?
  email          String?
  phone          String?
  deadline       DateTime? @db.Date
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  sourceMessageId String? @map("source_message_id")

  // Relations
  createdBy User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  votes     ReconstructionVote[]

  @@map("reconstruction_items")
}

model ReconstructionVote {
  itemId String @map("item_id")
  userId String @map("user_id")

  // Relations
  item ReconstructionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([itemId, userId])
  @@map("reconstruction_votes")
}

// ============================================================================
// RESERVATION WATCHER — Hlídácí pes termínů
// ============================================================================
model ReservationWatcher {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  reservationId String   @map("reservation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([userId, reservationId])
  @@map("reservation_watchers")
}

// ============================================================================
// INVENTORY (Zásoby na chatě)
// ============================================================================
model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("OSTATNÍ")
  status      String   @default("OK")   // OK | LOW | EMPTY
  location    String?                   // Kde to leží, např. "Kůlna"
  inCart      Boolean  @default(false) @map("in_cart")
  isEssential Boolean  @default(false) @map("is_essential")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  // Relations
  updatedBy   User?    @relation("UpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("inventory_items")
}

// ============================================================================
// USER AVAILABILITY (Osobní volno / Dovolené)
// Multi-tenant: workspaceId bude přidán po zavedení Workspace modelu
// ============================================================================
model UserAvailability {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_availabilities")
}

// ============================================================================
// SYSTEM LOG (centrální logování chyb pro Super Admin)
// ============================================================================
model SystemLog {
  id        String   @id @default(uuid())
  level     String   // "ERROR", "WARN", "INFO"
  message   String   @db.Text
  metadata  Json?    // stack trace, request body, error details
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("system_logs")
}
